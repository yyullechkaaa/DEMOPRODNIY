<Page x:Class="demoshoes.Pages.AdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:demoshoes.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="AdminPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock x:Name="UserFIO" Style="{StaticResource TextStyle}" HorizontalAlignment="Right" Margin="10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="OrdersButton" Click="OrdersButton_Click" Content="Заказы" Style="{StaticResource ButtonStyle}" Width="100"/>
                <Button x:Name="LogOutButton" Click="LogOutButton_Click" Content="Выйти" Style="{StaticResource ButtonStyle}" Width="100"/>
            </StackPanel>

        </Grid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="5" HorizontalAlignment="Center">
            <TextBox x:Name="SearchBox" Style="{StaticResource TextBoxStyle}" Width="200" TextChanged="SearchBox_TextChanged" Margin="5"/>
            <ComboBox x:Name="SupplierFilter" Width="150" Style="{StaticResource ComboStyle}" DisplayMemberPath="SupplierName" Margin="5" SelectionChanged="SupplierFilter_SelectionChanged"/>
            <!--Сортировка только по количеству на складе по возрастанию и убыванию-->
            <ComboBox x:Name="SortBox" Width="150" Style="{StaticResource ComboStyle}" SelectionChanged="SortBox_SelectionChanged" Margin="5">
                <ComboBoxItem Content="По возрастанию"/>
                <ComboBoxItem Content="По убыванию"/>
            </ComboBox>
            <!--Сортировка по возрастанию и убыванию И ПО ЦЕНЕ И ПО КОЛИЧЕСТВУ НА СКЛАДЕ-->
            <ComboBox x:Name="SortTwoBox" Width="200" Style="{StaticResource ComboStyle}" SelectionChanged="SortTwoBox_SelectionChanged" Margin="5">
                <ComboBoxItem Content="По возрастанию цены"/>
                <ComboBoxItem Content="По убыванию цены"/>
                <ComboBoxItem Content="По возрастанию количества на складе"/>
                <ComboBoxItem Content="По убыванию количества на складе"/>
            </ComboBox>
            <!--Фильтрация по размерам скидки-->
            <ComboBox x:Name="FilterDiscountBox" Width="200" Style="{StaticResource ComboStyle}" SelectionChanged="FilterDiscountBox_SelectionChanged" Margin="5">
                <ComboBoxItem Content="от 0 до 10,99%"/>
                <ComboBoxItem Content="от 11 до 14,99%"/>
                <ComboBoxItem Content="от 15% и более"/>
            </ComboBox>
        </StackPanel>

        <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
            <ListView x:Name="ShoesProductListView" MouseDoubleClick="ShoesProductListView_MouseDoubleClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="1300"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Image Source="{Binding PhotoImage}" Width="80" Height="80" Grid.Column="0"/>

                            <StackPanel Grid.Column="1" Margin="5">
                                <TextBlock Style="{StaticResource TextStyle}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} | {1}">
                                            <Binding Path="Category.CategoryName"/>
                                            <Binding Path="ProductName"/>
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Style="{StaticResource TextStyle}"> Описание: <Run Text="{Binding Description}"/> </TextBlock>
                                <TextBlock Style="{StaticResource TextStyle}"> Производитель: <Run Text="{Binding Manufacturer.ManufacturerName}"/> </TextBlock>
                                <TextBlock Style="{StaticResource TextStyle}"> Поставщик: <Run Text="{Binding Supplier.SupplierName}"/> </TextBlock>
                                <StackPanel Orientation="Horizontal" Margin="0,5,0,0">
                                    <TextBlock Style="{StaticResource TextStyle}" VerticalAlignment="Center">Цена:</TextBlock>
                                    <TextBlock Text="{Binding OldPriceText}" 
                                               Foreground="Red" Style="{StaticResource TextStyle}"
                                               TextDecorations="Strikethrough"
                                               VerticalAlignment="Center"/>
                                    <TextBlock Text="{Binding FinalPriceText}" Style="{StaticResource TextStyle}"
                                               Foreground="Black"
                                               VerticalAlignment="Center"
                                               Margin="5,0,0,0"/>
                                </StackPanel>
                                <TextBlock Style="{StaticResource TextStyle}"> Единица измерения: <Run Text="{Binding Units.UnitName}"/> </TextBlock>
                                <TextBlock Style="{StaticResource TextStyle}"> Количество на складе: <Run Text="{Binding CountStore}"/> </TextBlock> 
                            </StackPanel>

                            <TextBlock Grid.Column="2" Margin="10,0" Text="{Binding Discount, StringFormat={}{0}%}" Style="{StaticResource TextStyle}" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Добавить" x:Name="AddButton" Click="AddButton_Click" Style="{StaticResource ButtonStyle}" Width="200"/>
            <Button Content="Удалить выбранное" x:Name="DeleteButton" Click="DeleteButton_Click" Style="{StaticResource ButtonStyle}" Width="200"/>
        </StackPanel>
    </Grid>
</Page>
