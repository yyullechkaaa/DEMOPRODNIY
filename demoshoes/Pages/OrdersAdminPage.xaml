<Page x:Class="demoshoes.Pages.OrdersAdminPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:demoshoes.Pages"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="OrdersAdminPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <TextBlock x:Name="UserFIO" Style="{StaticResource TextStyle}" HorizontalAlignment="Right" Margin="10"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button x:Name="LogOutButton" Click="LogOutButton_Click" Content="Выйти" Style="{StaticResource ButtonStyle}" Width="100"/>
            </StackPanel>

        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Visible">
            <ListView x:Name="OrdersListView" MouseDoubleClick="OrdersListView_MouseDoubleClick">
                <ListView.ItemTemplate>
                    <DataTemplate>
                        <Grid Margin="5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1300"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Vertical" Grid.Column="0">
                                <TextBlock Text="{Binding ArticleOrder}" Style="{StaticResource TextStyle}"/>
                                <TextBlock Text="{Binding Status.StatusName}" Style="{StaticResource TextStyle}"/>
                                <TextBlock Text="{Binding Address.AddressName}" Style="{StaticResource TextStyle}"/>
                                <TextBlock Text="{Binding DateOrder, StringFormat=dd-MM-yyyy}" Style="{StaticResource TextStyle}"/>
                            </StackPanel>
                            <TextBlock Grid.Column="1" HorizontalAlignment="Right" Text="{Binding DateDelivery, StringFormat=dd-MM-yyyy}" Style="{StaticResource TextStyle}"/>
                        </Grid>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>
        </ScrollViewer>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center">
            <Button Content="Добавить заказ" x:Name="AddButton" Click="AddButton_Click" Style="{StaticResource ButtonStyle}" Width="200"/>
            <Button Content="Удалить выбранное" x:Name="DeleteButton" Click="DeleteButton_Click" Style="{StaticResource ButtonStyle}" Width="200"/>
        </StackPanel>
    </Grid>
</Page>
