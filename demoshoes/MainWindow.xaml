<Window x:Class="demoshoes.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:demoshoes"
        mc:Ignorable="d"
        Title="Обувь" Height="450" Width="800" Style="{StaticResource PageBack}">
    <Grid>
        <Grid.RowDefinitions>
            
            <RowDefinition Height="Auto"/>
            
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button x:Name="BackButton" Click="BackButton_Click" Style="{StaticResource ButtonStyle}" Grid.Row="0" HorizontalAlignment="Right" Content="Назад"/>
        <Image x:Name="ImageLogo" Source="images/Icon.png" Style="{StaticResource ImageStyle}" Grid.Row="0"/>
        <Frame x:Name="MainFrame" Style="{StaticResource FrameBack}" Grid.Row="1" NavigationUIVisibility="Hidden"/>

    </Grid>
</Window>
